{
  "compilerOptions": {
    "module": "commonjs",
    "target": "ES2021",
    "types": ["node"],

    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "strictPropertyInitialization": false,

    "sourceMap": true,
    "outDir": "./dist",

    "incremental": true,
    "skipLibCheck": true,
    "strictNullChecks": true,

    "esModuleInterop": true
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  }
}